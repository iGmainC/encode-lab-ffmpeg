# Encode Lab FFmpeg runtime version pins.
FFMPEG_VERSION="${FFMPEG_VERSION:-8.1.1}"
FFMPEG_SOURCE_URL="${FFMPEG_SOURCE_URL:-https://ffmpeg.org/releases/ffmpeg-${FFMPEG_VERSION}.tar.xz}"
VULKAN_HEADERS_VERSION="${VULKAN_HEADERS_VERSION:-v1.4.350}"
VULKAN_HEADERS_SOURCE_URL="${VULKAN_HEADERS_SOURCE_URL:-https://github.com/KhronosGroup/Vulkan-Headers.git}"
LIBPLACEBO_VERSION="${LIBPLACEBO_VERSION:-v7.360.1}"
LIBPLACEBO_SOURCE_URL="${LIBPLACEBO_SOURCE_URL:-https://code.videolan.org/videolan/libplacebo.git}"
